{
  "name": "graphql-api-gateway",
  "version": "1.0.0",
  "description": "GraphQL API Gateway aggregating academic REST APIs into a unified schema",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "test": "jest --forceExit --detectOpenHandles",
    "test:coverage": "jest --coverage --forceExit --detectOpenHandles",
    "lint": "eslint src/ --ext .ts"
  },
  "keywords": ["graphql", "api-gateway", "apollo-server", "typescript", "academic"],
  "license": "MIT",
  "dependencies": {
    "@apollo/server": "^4.11.0",
    "axios": "^1.7.0",
    "cors": "^2.8.5",
    "dataloader": "^2.2.3",
    "express": "^4.21.0",
    "graphql": "^16.9.0",
    "graphql-tag": "^2.12.6",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.0",
    "@types/uuid": "^10.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.0"
  }
}
